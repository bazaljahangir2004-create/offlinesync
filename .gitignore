# --- Sensitive files - never commit these ---
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# Note: firebase_options.dart contains Firebase project config.
# For a portfolio project this is API-key-like data tied to your
# specific Firebase project - while Firebase designs these to be
# used client-side and protected by security rules (not secret in
# the traditional sense), it's still good practice to keep project-
# specific identifiers out of a public repo. If you want recruiters
# to see this exact code, add a firebase_options.example.dart with
# placeholder values instead, and reference that in your README.